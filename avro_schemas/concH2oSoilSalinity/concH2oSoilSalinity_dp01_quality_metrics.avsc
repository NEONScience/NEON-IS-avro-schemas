  "type": "record",
  "name": "concH2oSoilSalinity_dp01_quality_metrics",
  "namespace": "org.neonscience.schema.dp01",
  "doc": "L1 quality metrics and final quality flags for soil water content and volumetric soil ion content from the EnviroSCAN sensor, for all depth positions combined",
